{
  "appId": "com.motifanalyzer.admin",
  "productName": "Motif Analyzer Admin",
  "icon": "public/app-logo.png",
  "directories": {
    "app": "admin-dashboard",
    "output": "release-admin"
  },
  "files": [
    "main.js",
    "preload.js",
    "index.html",
    "app-logo.png"
  ],
  "extraResources": [
    { "from": "tools/private.key",     "to": "private.key" },
    { "from": "tools/nsis",            "to": "nsis" },
    { "from": "tools/7za.exe",         "to": "7za.exe" },
    { "from": "tools/app-template.7z", "to": "app-template.7z" }
  ],
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64", "arm64"] }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "include": "tools/admin-install.nsh"
  }
}
